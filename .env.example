# Runtime profile
APP_ENV=development
DATA_MODE=MOCK
SERVICE_VERSION=0.1.0
SPRING_PROFILES_ACTIVE=development
WEB_BIND_ADDRESS=127.0.0.1
WEB_HOST_PORT=3000
API_BIND_ADDRESS=127.0.0.1
API_HOST_PORT=8080
ANALYTICS_BIND_ADDRESS=127.0.0.1
ANALYTICS_HOST_PORT=8000
DEMO_PRINCIPAL_ENABLED=true
DEMO_PRINCIPAL_USERNAME=demo
DEMO_PRINCIPAL_PASSWORD=change_me_demo_only
SERVICE_JWT_ENABLED=false
SERVICE_JWT_ISSUER=ai-quant-web
SERVICE_JWT_AUDIENCE=ai-quant-api
SERVICE_JWT_SUBJECT=primary-owner
SERVICE_JWT_EMAIL=bw2754@nyu.edu
SERVICE_JWT_HMAC_SECRET=
SERVICE_JWT_TOKEN_TTL=60s
API_INTERNAL_BASE_URL=http://api:8080
ANALYTICS_INTERNAL_BASE_URL=http://analytics:8000

# PostgreSQL
POSTGRES_DB=quant_research
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Logging
LOG_LEVEL=INFO

# OpenAI. Leave blank to use the deterministic Phase 3 Mock LLM implementation.
OPENAI_API_KEY=
# Optional shared-model fallback retained for the original v1 environment contract.
OPENAI_MODEL=
OPENAI_REPORT_MODEL=
OPENAI_VALIDATION_MODEL=
# Approved endpoints are the official OpenAI API or the explicitly reviewed LanYi host.
OPENAI_BASE_URL=https://api.openai.com
OPENAI_TIMEOUT=45s
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=12000
OPENAI_MAX_INPUT_BYTES=500000
OPENAI_MAX_TOOL_OUTPUT_BYTES=32768
OPENAI_MAX_TOOL_ROUNDS=3
OPENAI_BUDGET_RESERVATION_TTL=3m
OPENAI_ALLOW_SAFE_FALLBACK=true
OPENAI_SAFETY_HMAC_SECRET=
OPENAI_REPORT_PROMPT_VERSION=report_prompt_v1
OPENAI_REPORT_SCHEMA_VERSION=research_report_v1

# Versioned pricing must be supplied before REAL LLM calls are enabled.
# Values are USD per one million tokens; do not guess or copy stale prices.
OPENAI_PRICING_VERSION=
OPENAI_PRICING_EFFECTIVE_FROM=
OPENAI_INPUT_USD_PER_MILLION_TOKENS=
OPENAI_CACHED_INPUT_USD_PER_MILLION_TOKENS=
OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=

# Replaceable data providers
MARKET_DATA_PROVIDER=mock
MARKET_DATA_API_KEY=
MARKET_DATA_LICENSE_CONFIRMED=false
MARKET_DATA_LICENSE_POLICY_VERSION=
TIINGO_BASE_URL=https://api.tiingo.com
TIINGO_API_KEY=
TIINGO_USER_AGENT="AI Quant Research Assistant"
TIINGO_TIMEOUT=20s
TIINGO_MAX_RESPONSE_BYTES=10000000
TIINGO_MAX_ATTEMPTS=3
FUNDAMENTAL_DATA_PROVIDER=mock
FUNDAMENTAL_DATA_API_KEY=
FILING_DATA_PROVIDER=mock
SEC_USER_AGENT=
SEC_COMPANY_TICKERS_EXCHANGE_URL=https://www.sec.gov/files/company_tickers_exchange.json
SEC_TIMEOUT=20s
SEC_MAX_REQUESTS_PER_SECOND=8
SEC_MAX_FILINGS=6
SEC_MAX_JSON_BYTES=10000000
SEC_MAX_FILING_BYTES=20000000
SEC_MAX_ATTEMPTS=3
MACRO_DATA_PROVIDER=mock
FRED_API_KEY=
FRED_USER_AGENT="AI Quant Research Assistant"
FRED_SERIES_IDS=DFF,CPIAUCSL
FRED_OBSERVATION_START=2015-01-01
FRED_TIMEOUT=20s
FRED_MAX_OBSERVATIONS=10000
FRED_MAX_RESPONSE_BYTES=5000000
FRED_MAX_REQUESTS_PER_SECOND=2
FRED_MAX_ATTEMPTS=3
PROVIDER_CACHE_TTL=6h
PROVIDER_MAX_CACHE_ENTRY_BYTES=5000000

# Deterministic export resource boundaries
REPORT_MAX_PDF_BYTES=26214400
REPORT_MAX_PDF_PAGES=200
REPORT_MAX_FONT_BYTES=52428800

# Research budgets
RESEARCH_MAX_LLM_COST_USD=1.00
RESEARCH_MAX_LLM_CALLS=10

# Embedded durable Worker defaults
RESEARCH_WORKER_ENABLED=true
RESEARCH_WORKER_ID=api-worker-1
RESEARCH_WORKER_CONCURRENCY=2
RESEARCH_WORKER_POLL_DELAY=250ms
RESEARCH_WORKER_HEARTBEAT_DELAY=10s
RESEARCH_WORKER_REAPER_DELAY=15s
RESEARCH_WORKER_LEASE_DURATION=60s
RESEARCH_MAX_EXECUTION_MINUTES=15
RESEARCH_WORKER_RETRY_BASE_DELAY_SECONDS=1
RESEARCH_WORKER_RETRY_MAX_DELAY_SECONDS=30

# Transactional outbox relay
OUTBOX_RELAY_ENABLED=true
OUTBOX_RELAY_DELAY=1s
OUTBOX_RELAY_INITIAL_DELAY=2s
OUTBOX_RELAY_BATCH_SIZE=100

# R3-compatible retention defaults remain disabled in local development.
RETENTION_ENABLED=false
RESEARCH_ARTIFACT_RETENTION_DAYS=1095
PROVIDER_RAW_RETENTION_DAYS=365
BACKUP_RETENTION_DAYS=90
BACKUP_RUNTIME_PROFILE=shared-host
OPENSSL_BIN=openssl
RETENTION_BATCH_SIZE=100
RETENTION_INITIAL_DELAY=10m
RETENTION_SWEEP_DELAY=24h
