# Runtime profile
APP_ENV=development
DATA_MODE=MOCK
SERVICE_VERSION=0.1.0
SPRING_PROFILES_ACTIVE=development
DEMO_PRINCIPAL_ENABLED=true
DEMO_PRINCIPAL_USERNAME=demo
DEMO_PRINCIPAL_PASSWORD=change_me_demo_only

# PostgreSQL
POSTGRES_DB=quant_research
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Logging
LOG_LEVEL=INFO

# Phase 2+ reserved settings. The Phase 1 skeleton intentionally does not consume them.
# OpenAI. Leave blank to use the future Mock LLM implementation.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_REPORT_MODEL=
OPENAI_VALIDATION_MODEL=
OPENAI_STORE_RESPONSES=false

# Replaceable data providers
MARKET_DATA_PROVIDER=mock
MARKET_DATA_API_KEY=
FUNDAMENTAL_DATA_PROVIDER=mock
FUNDAMENTAL_DATA_API_KEY=
SEC_USER_AGENT=
FRED_API_KEY=

# Research budgets
RESEARCH_MAX_LLM_COST_USD=1.00
RESEARCH_MAX_LLM_CALLS=10
RESEARCH_MAX_EXECUTION_MINUTES=15

# Worker lease defaults
RESEARCH_WORKER_POLL_INTERVAL_MS=1000
RESEARCH_JOB_LEASE_SECONDS=60
RESEARCH_JOB_HEARTBEAT_SECONDS=15
