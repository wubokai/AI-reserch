# Production profile: single-owner, private Tailscale access, REAL providers.
APP_ENV=production
DATA_MODE=REAL
SPRING_PROFILES_ACTIVE=production
SERVICE_VERSION=1.0.0
WEB_BIND_ADDRESS=127.0.0.1
WEB_HOST_PORT=3000
API_BIND_ADDRESS=127.0.0.1
API_HOST_PORT=8080
ANALYTICS_BIND_ADDRESS=127.0.0.1
ANALYTICS_HOST_PORT=8000
DEMO_PRINCIPAL_ENABLED=false
DEMO_PRINCIPAL_USERNAME=
DEMO_PRINCIPAL_PASSWORD=

# Short-lived Web -> API bearer JWT. Generate locally; never commit the value.
SERVICE_JWT_ENABLED=true
SERVICE_JWT_ISSUER=ai-quant-web
SERVICE_JWT_AUDIENCE=ai-quant-api
SERVICE_JWT_SUBJECT=primary-owner
SERVICE_JWT_EMAIL=bw2754@nyu.edu
SERVICE_JWT_HMAC_SECRET=
SERVICE_JWT_TOKEN_TTL=60s

# PostgreSQL / Redis
POSTGRES_DB=quant_research
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379

# LanYi: approved exact third-party Responses-compatible endpoint.
# Rotate any key that has ever appeared in chat, logs, shell history, or Git.
OPENAI_BASE_URL=https://lanyiapi.com/v1/
OPENAI_API_KEY=
OPENAI_REPORT_MODEL=gpt-5.5
OPENAI_VALIDATION_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=xhigh
OPENAI_TIMEOUT=90s
OPENAI_MAX_OUTPUT_TOKENS=12000
OPENAI_MAX_INPUT_BYTES=500000
OPENAI_MAX_TOOL_OUTPUT_BYTES=32768
OPENAI_MAX_TOOL_ROUNDS=3
OPENAI_ALLOW_SAFE_FALLBACK=true
OPENAI_SAFETY_HMAC_SECRET=
OPENAI_REPORT_PROMPT_VERSION=report_prompt_v1
OPENAI_REPORT_SCHEMA_VERSION=research_report_v1
# Fill these from the LanYi account's exact billing table before first REAL call.
OPENAI_PRICING_VERSION=
OPENAI_PRICING_EFFECTIVE_FROM=
OPENAI_INPUT_USD_PER_MILLION_TOKENS=
OPENAI_CACHED_INPUT_USD_PER_MILLION_TOKENS=
OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=
RESEARCH_MAX_LLM_COST_USD=1.00
RESEARCH_MAX_LLM_CALLS=10

# Tiingo Individual/Starter: strictly personal internal use, no redistribution.
MARKET_DATA_PROVIDER=tiingo
MARKET_DATA_LICENSE_CONFIRMED=true
MARKET_DATA_LICENSE_POLICY_VERSION=tiingo_individual_internal_v1_2026_02_18
MARKET_DATA_API_KEY=
TIINGO_API_KEY=
TIINGO_BASE_URL=https://api.tiingo.com
TIINGO_USER_AGENT="AI Quant Research Assistant"
TIINGO_TIMEOUT=20s
TIINGO_MAX_RESPONSE_BYTES=10000000
TIINGO_MAX_ATTEMPTS=3

# Official SEC Filing + XBRL and FRED macro data.
FUNDAMENTAL_DATA_PROVIDER=sec-xbrl
FILING_DATA_PROVIDER=sec
SEC_USER_AGENT="AI Quant Research Assistant bw2754@nyu.edu"
SEC_COMPANY_TICKERS_EXCHANGE_URL=https://www.sec.gov/files/company_tickers_exchange.json
SEC_TIMEOUT=20s
SEC_MAX_REQUESTS_PER_SECOND=8
SEC_MAX_FILINGS=6
SEC_MAX_JSON_BYTES=10000000
SEC_MAX_FILING_BYTES=20000000
SEC_MAX_ATTEMPTS=3
MACRO_DATA_PROVIDER=fred
FRED_API_KEY=
FRED_USER_AGENT="AI Quant Research Assistant bw2754@nyu.edu"
FRED_SERIES_IDS=DFF,CPIAUCSL
FRED_OBSERVATION_START=2015-01-01
FRED_TIMEOUT=20s
FRED_MAX_OBSERVATIONS=10000
FRED_MAX_RESPONSE_BYTES=5000000
FRED_MAX_REQUESTS_PER_SECOND=2
FRED_MAX_ATTEMPTS=3

# R3 retention profile.
RESEARCH_ARTIFACT_RETENTION_DAYS=1095
PROVIDER_NORMALIZED_RETENTION_DAYS=1095
PROVIDER_RAW_RETENTION_DAYS=365
BACKUP_RETENTION_DAYS=90
BACKUP_RUNTIME_PROFILE=production
OPENSSL_BIN=openssl
RETENTION_ENABLED=true
RETENTION_BATCH_SIZE=100
RETENTION_INITIAL_DELAY=10m
RETENTION_SWEEP_DELAY=24h
BACKUP_DIR=/var/backups/ai-quant-research
BACKUP_PASSPHRASE_FILE=.secrets/backup-passphrase
BACKUP_REMOTE=

PROVIDER_CACHE_TTL=6h
PROVIDER_MAX_CACHE_ENTRY_BYTES=5000000
RESEARCH_WORKER_ENABLED=true
RESEARCH_WORKER_ID=api-worker-1
RESEARCH_WORKER_CONCURRENCY=2
RESEARCH_MAX_EXECUTION_MINUTES=30
OUTBOX_RELAY_ENABLED=true
LOG_LEVEL=INFO
