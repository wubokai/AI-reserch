{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local.ai-quant-research-assistant.dev/llm/fundamental-narrative-v1.json",
  "title": "Fundamental Narrative v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "fundamental_narrative_v1"
    },
    "summaryClaims": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "claimType": {
            "type": "string",
            "enum": ["FACT", "CALCULATION", "INFERENCE"]
          },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^ev_[A-Za-z0-9_-]{1,64}$"
            }
          },
          "calculationIds": {
            "type": "array",
            "maxItems": 12,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^calc_[A-Za-z0-9_-]{1,64}$"
            }
          },
          "limitations": {
            "type": "array",
            "maxItems": 10,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        },
        "required": [
          "statement",
          "claimType",
          "evidenceIds",
          "calculationIds",
          "limitations"
        ]
      }
    },
    "missingData": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    },
    "limitations": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  },
  "required": ["schemaVersion", "summaryClaims", "missingData", "limitations"]
}
