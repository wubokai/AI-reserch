{
  "name": "ai-quant-research-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-backed AI research platform for US equities and ETFs",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @ai-quant/web dev",
    "lint:web": "pnpm --filter @ai-quant/web lint",
    "typecheck:web": "pnpm --filter @ai-quant/web typecheck",
    "test:web": "pnpm --filter @ai-quant/web test",
    "build:web": "pnpm --filter @ai-quant/web build",
    "e2e:web": "pnpm --filter @ai-quant/web e2e"
  }
}
